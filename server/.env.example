# ==========================================
# MovieMonk Backend — Environment Variables
# ==========================================
# Copy to `.env` for local development.
# For HuggingFace Spaces, add these as Space Secrets.
# NEVER commit actual secrets to version control.

# ── TMDB (Required) ──
TMDB_API_KEY=your_tmdb_v3_api_key
TMDB_READ_TOKEN=your_tmdb_v4_read_token

# ── OMDB (Optional — enables IMDb/RT/Metacritic ratings) ──
OMDB_API_KEY=your_omdb_api_key

# ── AI Providers ──
GROQ_API_KEY=your_groq_api_key
VIBE_SEARCH_API_KEY=your_secondary_groq_key
PERPLEXITY_API_KEY=your_perplexity_api_key

# ── Web Search (Optional) ──
SERPAPI_KEY=your_serpapi_key

# ── Supabase (Server-side — service role for JWT verification + DB) ──
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Redis Cache (Optional — caching disabled if not set) ──
REDIS_URL=redis://localhost:6379/0

# ── CORS (Comma-separated allowed origins) ──
ALLOWED_ORIGINS=https://moviemonk-ai.vercel.app,http://localhost:3000,http://127.0.0.1:3000
