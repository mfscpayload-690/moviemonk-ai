# ==========================================
# MovieMonk Environment Setup
# ==========================================
# Copy this file to `.env.local` for local development.
# DO NOT commit your actual `.env.local` file to version control.

# ── Metadata APIs ──
# TMDB API (Get from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_v3_api_key
TMDB_READ_TOKEN=your_tmdb_v4_read_token

# OMDB API (Get from https://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=your_omdb_api_key

# ── AI / LLM Providers ──
# Groq API (Get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key

# Perplexity API (Optional fallback)
PERPLEXITY_API_KEY=your_perplexity_api_key

# SerpApi Key (For web searches)
SERPAPI_KEY=your_serpapi_key

# ── Supabase (Frontend) ──
# Local Vite dev will pick up these variables natively.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# NOTE ON OAUTH (Google & GitHub):
# You do NOT need to add Google or GitHub Client Secrets to this .env file.
# Supabase handles OAuth natively. Simply enter your Google/GitHub API keys 
# exactly once directly inside the Supabase Dashboard -> Authentication -> Providers.

# ── Backend / Admin (Server-side Only) ──
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Web Push (VAPID)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:notifications@yourdomain.com
